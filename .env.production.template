# =============================================================================
# StickerApp backend — production env template
#
# Copy this file to `.env.production` on the VPS at /opt/stickerapp/.
# Fill in the placeholders. Permissions on the real file: chmod 600.
# NEVER commit the real .env.production.
# =============================================================================

# --- Django -------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_DEBUG=False
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=REPLACE_WITH_LONG_RANDOM_STRING
# Comma-separated. Include the apex domain and any subdomains we serve from.
DJANGO_ALLOWED_HOSTS=stickerapp.example.com,www.stickerapp.example.com
# Stays the same as dev unless the client wants a custom admin path.
ADMIN_URL=django-admin/

# --- Database -----------------------------------------------------------------
POSTGRES_DB=stickerapp
POSTGRES_USER=stickerapp
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://stickerapp:REPLACE_WITH_STRONG_PASSWORD@db:5432/stickerapp

# --- Frontend / CORS / CSRF ---------------------------------------------------
FRONTEND_URL=https://stickerapp.example.com
CORS_ALLOWED_ORIGINS=https://stickerapp.example.com
CSRF_TRUSTED_ORIGINS=https://stickerapp.example.com

# --- Email (Gmail SMTP w/ App Password) ---------------------------------------
# Use Django's SMTP backend in prod (NOT the console backend from dev).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=endosestudio@gmail.com
# App Password from Google Account → Security → 2FA → App Passwords.
# NOT the owner's regular Gmail password.
EMAIL_HOST_PASSWORD=REPLACE_WITH_GMAIL_APP_PASSWORD
DEFAULT_FROM_EMAIL=EnDosEstudio <endosestudio@gmail.com>
# Where new-order notifications are sent. Often == EMAIL_HOST_USER.
SHOP_OWNER_EMAIL=endosestudio@gmail.com

# --- Stripe (test keys on day 1; swap to live keys via env-update flow) -------
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
# Empty on first deploy. Fill in after registering the webhook URL
# (https://<domain>/api/v1/payments/webhooks/stripe/) in Stripe dashboard.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
