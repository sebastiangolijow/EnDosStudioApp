# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev
ADMIN_URL=django-admin/

# Database
DATABASE_URL=postgres://stickerapp:stickerapp@db:5432/stickerapp

# Postgres (used by docker-compose and config/settings/test.py)
POSTGRES_DB=stickerapp
POSTGRES_USER=stickerapp
POSTGRES_PASSWORD=stickerapp
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Frontend
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Email (console backend in dev; configure SMTP for prod)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@stickerapp.local
# Where new-order notifications are sent. Falls back to
# DEFAULT_FROM_EMAIL when blank.
SHOP_OWNER_EMAIL=owner@stickerapp.local

# Stripe (use test keys for dev)
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
